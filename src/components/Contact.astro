---
import Section from './Section.astro';

const contactLinks = [
  {
    label: 'Email',
    value: 'will@example.com',
    href: 'mailto:will@example.com',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" /></svg>',
  },
  {
    label: 'LinkedIn',
    value: 'linkedin.com/in/will',
    href: 'https://linkedin.com/in/will',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>',
  },
  {
    label: 'GitHub',
    value: 'github.com/will',
    href: 'https://github.com/will',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>',
  },
];
---

<Section id="contacto" title="Contacto" subtitle="¿Tienes un proyecto en mente? Hablemos">
  <div class="grid md:grid-cols-2 gap-10 items-start">
    <!-- Left: Message -->
    <div class="animate-on-scroll space-y-6">
      <p class="text-dark-300 text-lg leading-relaxed">
        Estoy abierto a oportunidades laborales, proyectos freelance y
        colaboraciones interesantes. Si buscas un desarrollador con
        <span class="text-white font-medium">experiencia real en producción</span>
        y enfoque en calidad, no dudes en contactarme.
      </p>

      <div class="space-y-4">
        {
          contactLinks.map((link) => (
            <a
              href={link.href}
              target="_blank"
              rel="noopener"
              class="group flex items-center gap-4 p-4 rounded-xl border border-dark-800 bg-dark-900/30 hover:border-primary-500/20 hover:bg-dark-900/60 transition-all duration-300"
            >
              <div class="p-2.5 rounded-lg bg-primary-500/10 text-primary-400 group-hover:bg-primary-500/20 transition-colors" set:html={link.icon} />
              <div>
                <p class="text-xs text-dark-500 uppercase tracking-wider font-medium">{link.label}</p>
                <p class="text-dark-200 font-medium group-hover:text-primary-300 transition-colors">{link.value}</p>
              </div>
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 ml-auto text-dark-600 group-hover:text-primary-400 group-hover:translate-x-1 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75" />
              </svg>
            </a>
          ))
        }
      </div>
    </div>

    <!-- Right: Quick form / CTA -->
    <div class="animate-on-scroll">
      <div class="p-8 rounded-2xl border border-dark-800 bg-gradient-to-br from-dark-900/80 to-dark-950/80">
        <h3 class="text-xl font-semibold text-white mb-2">Trabajemos juntos</h3>
        <p class="text-dark-400 text-sm mb-6">Cuéntame sobre tu proyecto y te responderé a la brevedad.</p>

        <form action="https://formspree.io/f/YOUR_FORM_ID" method="POST" class="space-y-4">
          <div>
            <label for="name" class="block text-sm font-medium text-dark-300 mb-1.5">Nombre</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="w-full px-4 py-3 bg-dark-800/50 border border-dark-700 rounded-xl text-white placeholder-dark-500 focus:ring-2 focus:ring-primary-500/40 focus:border-primary-500/40 transition-colors text-sm"
              placeholder="Tu nombre"
            />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-dark-300 mb-1.5">Email</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full px-4 py-3 bg-dark-800/50 border border-dark-700 rounded-xl text-white placeholder-dark-500 focus:ring-2 focus:ring-primary-500/40 focus:border-primary-500/40 transition-colors text-sm"
              placeholder="tu@email.com"
            />
          </div>
          <div>
            <label for="message" class="block text-sm font-medium text-dark-300 mb-1.5">Mensaje</label>
            <textarea
              id="message"
              name="message"
              required
              rows="4"
              class="w-full px-4 py-3 bg-dark-800/50 border border-dark-700 rounded-xl text-white placeholder-dark-500 focus:ring-2 focus:ring-primary-500/40 focus:border-primary-500/40 transition-colors text-sm resize-none"
              placeholder="Describe tu proyecto o idea..."
            ></textarea>
          </div>
          <button
            type="submit"
            class="w-full py-3.5 bg-primary-600 text-white font-medium rounded-xl hover:bg-primary-500 transition-all duration-300 shadow-lg shadow-primary-600/20 hover:shadow-primary-500/30 text-sm"
          >
            Enviar mensaje
          </button>
        </form>
      </div>
    </div>
  </div>
</Section>
