---

<Section id="stack" title="Stack Tecnológico" subtitle="Tecnologías y herramientas que uso día a día">
  <div class="space-y-10 stagger-children">
    {
      categories.map((category) => (
        <div class="animate-on-scroll">
          <h3 class="text-sm font-semibold text-dark-400 uppercase tracking-wider mb-5">
            {category.title}
          </h3>
          <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3">
            {category.items.map((tech) => (
              <div class="group flex items-center gap-3 p-3.5 rounded-xl border border-dark-800 bg-dark-900/50 hover:border-primary-500/20 hover:bg-dark-800/50 transition-all duration-300">
                <div class={`w-6 h-6 flex-shrink-0 ${tech.color} opacity-70 group-hover:opacity-100 transition-opacity`} set:html={tech.icon} />
                <span class="text-sm text-dark-300 group-hover:text-white transition-colors font-medium truncate">
                  {tech.name}
                </span>
              </div>
            ))}
          </div>
        </div>
      ))
    }
  </div>
</Section>
