---
import Section from './Section.astro';

interface Course {
  name: string;
  platform: string;
}

interface EducationItem {
  title: string;
  institution: string;
  type: string;
  description?: string;
  icon: string;
  courses?: Course[];
}

const education: EducationItem[] = [
  {
    title: 'Ingeniería de Sistemas',
    institution: 'Universidad',
    type: 'Carrera Profesional',
    description: 'Formación integral en ingeniería de software, bases de datos, redes, arquitectura de sistemas y gestión de proyectos tecnológicos.',
    icon: '🎓',
  },
  {
    title: 'Formación Continua',
    institution: 'Udemy & Platzi',
    type: 'Certificaciones & Cursos',
    description: 'Actualización constante en tecnologías modernas, arquitectura de software y mejores prácticas del desarrollo web.',
    icon: '📚',
    courses: [
      { name: 'React Avanzado', platform: 'Udemy' },
      { name: 'Svelte desde Cero', platform: 'Udemy' },
      { name: 'NestJS - Backend Escalable', platform: 'Udemy' },
      { name: 'Clean Architecture', platform: 'Udemy' },
      { name: 'Docker & Contenedores', platform: 'Platzi' },
      { name: 'CI/CD Pipelines', platform: 'Platzi' },
      { name: '.NET & C# Profesional', platform: 'Udemy' },
      { name: 'TypeScript Avanzado', platform: 'Udemy' },
    ],
  },
];
---

<Section id="formacion" title="Formación" subtitle="Mi camino de aprendizaje continuo">
  <div class="space-y-8 stagger-children">
    {
      education.map((item) => (
        <div class="animate-on-scroll p-6 rounded-2xl border border-dark-800 bg-dark-900/30 hover:border-primary-500/15 transition-all duration-300">
          <div class="flex items-start gap-4 mb-4">
            <span class="text-3xl flex-shrink-0" role="img" aria-hidden="true">{item.icon}</span>
            <div class="flex-1">
              <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-1">
                <h3 class="text-lg font-semibold text-white">{item.title}</h3>
                <span class="px-2.5 py-0.5 text-xs font-medium rounded-full bg-primary-500/10 text-primary-300 border border-primary-500/20 w-fit">
                  {item.type}
                </span>
              </div>
              <p class="text-primary-400 font-medium text-sm mt-0.5">{item.institution}</p>
              {item.description && (
                <p class="text-dark-400 text-sm mt-3 leading-relaxed">{item.description}</p>
              )}
            </div>
          </div>

          {item.courses && (
            <div class="ml-0 sm:ml-14 mt-5">
              <h4 class="text-xs font-semibold text-dark-400 uppercase tracking-wider mb-3">
                Certificaciones & Cursos Destacados
              </h4>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
                {item.courses.map((course) => (
                  <div class="flex items-center gap-3 p-3 rounded-lg bg-dark-800/30 border border-dark-800 hover:border-dark-700 transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-primary-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 00-.491 6.347A48.62 48.62 0 0112 20.904a48.62 48.62 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.636 50.636 0 00-2.658-.813A59.906 59.906 0 0112 3.493a59.903 59.903 0 0110.399 5.84 51.39 51.39 0 00-2.658.814m-15.482 0A50.717 50.717 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5" />
                    </svg>
                    <div>
                      <p class="text-sm text-dark-200 font-medium">{course.name}</p>
                      <p class="text-xs text-dark-500">{course.platform}</p>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          )}
        </div>
      ))
    }
  </div>
</Section>
