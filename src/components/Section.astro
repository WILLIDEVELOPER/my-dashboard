---
interface Props {
  id: string;
  title: string;
  subtitle?: string;
}

const { id, title, subtitle } = Astro.props;
---

<section id={id} class="py-20 sm:py-28 relative">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="animate-on-scroll mb-14">
      <div class="flex items-center gap-4 mb-3">
        <div class="h-px w-12 bg-primary-500/50"></div>
        <h2 class="text-3xl sm:text-4xl font-bold text-white tracking-tight">
          {title}
        </h2>
      </div>
      {subtitle && (
        <p class="text-dark-400 text-lg ml-16">{subtitle}</p>
      )}
    </div>
    <slot />
  </div>
</section>
